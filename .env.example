# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Candidate Profile ─────────────────────────────────────────────────────────
# Your name
CANDIDATE_FIRST_NAME=Jane
CANDIDATE_LAST_NAME=Smith

# Email setup:
#   Application forms will use: {EMAIL_BASE}+jobs-{company}@{EMAIL_DOMAIN}
#   e.g. janesmith+jobs-google@gmail.com
#   Set up a Gmail filter to forward emails containing "+jobs" to FORWARDING_EMAIL
CANDIDATE_EMAIL_BASE=janesmith
CANDIDATE_EMAIL_DOMAIN=gmail.com
CANDIDATE_FORWARDING_EMAIL=mybot@gmail.com

# Contact info (used in form-filling and resume)
CANDIDATE_PHONE=555-867-5309
CANDIDATE_WEBSITE=janesmith.com
CANDIDATE_LINKEDIN=https://www.linkedin.com/in/janesmith/
CANDIDATE_LOCATION=Austin, TX

# Used in resume tailoring prompts to personalize advice about your main employer
CANDIDATE_CURRENT_EMPLOYER=Acme Corp
